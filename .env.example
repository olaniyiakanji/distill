# Google AI Studio (Gemini) API key — free tier is plenty for personal use.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Neon / Postgres connection string
# On Vercel: created automatically when you attach a Neon Postgres store.
# Locally: point at your Neon dev branch or any Postgres you can reach.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
